# Install and load R packages
install.packages(c("readxl", "metafor", "meta", "dplyr", "tidyr", "stringr", "metasens"))
if (!require("remotes")) {
  install.packages("remotes")
}
remotes::install_github("MathiasHarrer/dmetar")
library(readxl)
library(metafor)
library(meta)
library(metasens)
library(dmetar)
library(dplyr)
library(tidyr)
library(stringr)
library(readr)

#Data preparation
file_path <- "~/Library/CloudStorage/OneDrive-UniversityofBath/systematic review and meta-analysis/meta-analysis/ecig_intercon.xlsx"

#-----E-CIGARETTE USE AND INTERNALIZING PROBLEMS WITH CONTINUOUS OUTCOMES: DEPRESSION WAS INCLUDED WHEN THE PAPER REPORT MULTIPLE OUTCOMES OF INTEREST-----#
# Read the sheet 
ecig_intercon_depre <- read_excel(file_path, sheet = "internalizing_depression")
names(ecig_intercon_depre)
ecig_intercon_depre$TE<- as.numeric(ecig_intercon_depre$`standardized regression coefficient`)
ecig_intercon_depre$seTE <- as.numeric(ecig_intercon_depre$`standardized SE`)

#Meta-analysis
#Running random-effects meta-analysis using generic inverse variance method and Paule and Mandel for between-study variance names(ecig_intercon_depre)
Ecig_intercon_depre<- metagen(TE= TE, seTE= seTE, studlab = `ID`, data = ecig_intercon_depre, sm = "β Coefficient", common = FALSE, random = TRUE, method.tau = "PM")
summary (Ecig_intercon_depre)

#Generating forest plot
# Set up TIFF device with 800 DPI resolution
tiff("Ecig_intercon_depre.tiff", width = 26.0, height = 18.0, units = "cm", res = 600, compression = "lzw")

#Generating forest plot for meta-analysis results
forest(Ecig_intercon_depre, studlab = TRUE, prediction = TRUE, print.tau2 = TRUE, xlim = c(-0.6,0.6), leftlabs = c("ID", "β Coefficient", "SE"), fontfamily = "sans", fontsize = 8, col.predict = "darkgrey", col.predict.lines = "black")

# Close the TIFF device
dev.off()

#Outliers
#Finding outliers based on studies for which upper bound of 95% CI is lower than lower bound  pooled effect confidence interval, or lower bound of 95% CI is higher than upper bound of pooled effect.
Ecig_intercon_depre_out <- find.outliers(Ecig_intercon_depre)
summary (Ecig_intercon_depre_out)

#Subgroup analysis
sg_xtype_intercon <- update(Ecig_intercon_depre, subgroup = exp_type, tau.common = FALSE)
summary(sg_xtype_intercon)
sg_ctype_intercon <- update(Ecig_intercon_depre, subgroup = comp_type, tau.common = FALSE)
summary(sg_ctype_intercon)
sg_ytype_intercon <- update(Ecig_intercon_depre, subgroup = otcm_type, tau.common = FALSE)
summary(sg_ytype_intercon)
sg_age_intercon <- update(Ecig_intercon_depre, subgroup = age_grp, tau.common = FALSE)
summary(sg_age_intercon)
sg_pop_intercon <- update(Ecig_intercon_depre, subgroup = pop_type, tau.common = FALSE)
summary(sg_pop_intercon)

#Meta-regression
#Not run for % female due to high missing data and typically only reported for whole sample (i.e. may not represent exposure level used in main meta-analysis)
metareg(Ecig_intercon_depre, ~flw_up)
metareg(Ecig_intercon_depre, ~smpsize)

#Meta-biases
#LFK and Doi plot
lfk.Ecig_intercon <- lfkindex(ecig_intercon_depre$`standardized regression coefficient`, ecig_intercon_depre$`standardized SE`, data = ecig_intercon_depre)
doiplot(lfk.Ecig_intercon, xlab = "β Coefficient", pos.lfkindex = 9)

