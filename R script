#-----E-CIGARETTE USE AND INTERNALIZING PROBLEMS WITH DICHOTOMOUS OUTCOMES: DEPRESSION WAS INCLUDED WHEN THE PAPER REPORT MULTIPLE OUTCOMES OF INTEREST----#
#Data preparation
file_path <- "~/Library/CloudStorage/OneDrive-UniversityofBath/systematic review and meta-analysis/meta-analysis/ecig_interndicho.xlsx"
#Read the sheet 
ecig_interdicho_depre<- read_excel(file_path, sheet = "internalizing-dichotomous depre")

##-----WITHIN-STUDY POOLING FOR GENDER COMBINATION USING RANDON-EFFECT INVERSE VARIANCE META-ANALYSIS----##
ecig_interdicho_depre$TE<- as.numeric(ecig_interdicho_depre$`Adjusted log_RR`)
ecig_interdicho_depre$seTE <- as.numeric(ecig_interdicho_depre$`Adjusted log_SE`)
dat_combined_depress <- ecig_interdicho_depre %>%
  group_by(`ID`) %>%
  group_modify(~{
    
    res <- rma(
      yi     = .x$TE,
      sei    = .x$seTE,
      method = "PM"
    )
    
    tibble(
      TE   = as.numeric(res$b),
      seTE = res$se,
      tau2 = res$tau2
    )
  }) %>%
  ungroup()

#META-ANALYSIS
#Running random-effects meta-analysis using generic inverse variance method and Paule and Mandel for between-study variance names(dat_raw)
names(dat_combined_depress)
Ecig_interndicho_depre<- metagen(TE= TE, seTE= seTE, studlab = `ID`, data = dat_combined_depress, sm= "RR", common = FALSE, random = TRUE, method.tau = "PM")
summary (Ecig_interndicho_depre)

#GENERATING FOREST PLOT
# Set up TIFF device with 800 DPI resolution
tiff("Ecig_interndicho_depre.tiff", width = 30.0, height = 18.0, units = "cm", res = 600, compression = "lzw")

#Generating forest plot for meta-analysis results
forest(Ecig_interndicho_depre, studlab = TRUE, prediction = TRUE, print.tau2 = TRUE, xlim = c(0.1,10), leftlabs = c("ID", "log_RR", "SE"), fontfamily = "sans", fontsize = 8, col.predict = "darkgrey", col.predict.lines = "black")

# Close the TIFF device
dev.off()

#Outliers
#Finding outliers based on studies for which upper bound of 95% CI is lower than lower bound  pooled effect confidence interval, or lower bound of 95% CI is higher than upper bound of pooled effect.
Ecig_interndicho_depre_out<- find.outliers(Ecig_interndicho_depre)
summary (Ecig_interndicho_depre)

# Remove outlier studies from the data
Ecig_interndicho_depre_clean<- ecig_intercon_depre %>%
  filter(!`ID` %in% c("Conway 2025 A"))

# Re-run meta-analysis
