#----E-CIGARETTE USE AND INTERNALIZING PROBLESM WITH DICHOTOMOUS OUTCOMES----"
#Read the sheet 
ecig_interdicho <- read_excel(file_path, sheet = "internalizing-dichotomous meta")

#Exclude studies starting with "Conway" since it includes subgroup analysis by gender
library(dplyr)
ecig_interdicho_clean<- ecig_interdicho %>%
  filter(!grepl("^Conway", `ID`))

#Fixed-effect inverse-variance pooling
ecig_interdicho$TE<- as.numeric(ecig_interdicho$`Adjusted log_RR`)
ecig_interdicho$seTE<- as.numeric(ecig_interdicho$`Adjusted log_SE`)
dat_no_conway <- ecig_interdicho_clean %>%
  group_by(ID) %>%
  summarise(
    TE   = sum(TE / seTE^2) / sum(1 / seTE^2),
    seTE = sqrt(1 / sum(1 / seTE^2)),
    .groups = "drop"
  )

names(dat_no_conway)

# Random-effects pooling (Paule–Mandel) for gender
#Combining data_no_conway and ecig_interdicho soly including conway
dat_with_conway<- ecig_interdicho %>%
  filter(grepl("^Conway", ID))
library(dplyr)
dat_combined_interdicho<- bind_rows(
  dat_no_conway,
  dat_with_conway
)
dat_pooled_interdicho<- dat_combined_interdicho %>%
  group_by(`ID`) %>%
  group_modify(~{
    
    res <- rma(
      yi     = .x$TE,
      sei    = .x$seTE,
      method = "PM"
    )
    
    tibble(
      TE   = as.numeric(res$b),
      seTE = res$se,
      tau2 = res$tau2
    )
  }) %>%
  ungroup()

names(dat_pooled_interdicho)
summary(dat_pooled_interdicho)

#Meta-analysis
##Generate a new EXCEL sheet with updated effect estimates after pooling estimates
#Running random-effects meta-analysis using generic inverse variance method and Paule and Mandel for between-study variance names(dat_raw)
