  TE = dat_generated$TE,
  seTE = dat_generated$seTE,
  studlab = dat_generated$`ID`,
  data = dat_generated,
  sm = "RR",
  common = FALSE,
  random = TRUE,
  method.tau = "PM"
)
summary (Ecig_internalizing_dicho)

#Generating forest plot
# Set up TIFF device with 600 DPI resolution
tiff("Ecig_internalizing_dicho.tiff", width = 30, height = 18, units = "cm", res = 600)

#Generating forest plot for meta-analysis results
forest(Ecig_internalizing_dicho,
       studlab = TRUE,
       prediction = TRUE,
       print.tau2 = TRUE,
       xlim = c(0.1,10),
       leftlabs = c("ID", "log_RR", "SE"),
       fontfamily = "sans",
       fontsize = 8,
       col.predict = "darkgrey",
       col.predict.lines = "black")
dev.off()

# Close the TIFF device
